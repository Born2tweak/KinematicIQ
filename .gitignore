# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build
dist/
build/
*.egg-info/

# Logs
*.log

# Pose tapes are athlete motion data (validation dataset) — store them with
# the recordings, never in git (docs/validation/session-log.md).
# The README (labeling protocol + suite index) IS versioned.
eval-tapes/*
!eval-tapes/README.md
# Redacted example manifest only — a real MANIFEST.json stays local (M44).
!eval-tapes/MANIFEST.example.json
!eval-tapes/PROTOCOL_STUDY_MANIFEST.example.json

# Public-dataset raw bytes are LOCAL-ONLY (M61, ADR-006/ADR-010). Git tracks
# the metadata registry (web/eval/datasets/registry.json) and never the data:
# raw archives, extracted frames, video, participant-linked landmarks, or any
# credentials. The local cache lives here and stays out of git.
web/eval/datasets/local/
# Belt-and-suspenders: refuse common raw movement/media artifacts anywhere.
*.mp4
*.mov
*.avi
*.mkv
*.c3d
*.trc
*.bvh
*.mot
*.sto
# The registry itself is the ONLY tracked file under web/eval/datasets/.
web/eval/datasets/*
!web/eval/datasets/registry.json

# AutoClaw KDream data
.autoclaw/

.vercel

# claude-flow / ruflo local orchestration state
.claude-flow/
.swarm/
